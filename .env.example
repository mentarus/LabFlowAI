# MentraOS app credentials (from console.mentraglass.com)
# Package name must exactly match what's registered in the developer console
PACKAGE_NAME=com.yourname.gemini-bridge
MENTRAOS_API_KEY=your-mentraos-api-key-here

# Server port (must match your Cloudflare tunnel / public webhook URL)
PORT=3000

# Gemini API (from aistudio.google.com)
GEMINI_API_KEY=your-gemini-api-key-here

# Gemini model to use for analysis
GEMINI_MODEL=gemini-robotics-er-1.5-preview

# Generation config (match Python notebook defaults)
GEMINI_TEMPERATURE=0.2
GEMINI_THINKING_BUDGET=8192

# Public IP of this server — glasses push RTMP directly here
PUBLIC_IP=163.192.31.247

# RTMP port (default 1935 — must be open in Oracle Cloud VCN + OS firewall)
RTMP_PORT=1935

# Path to the MediaMTX binary
MEDIAMTX_BIN=/home/ubuntu/dev/biodexic-glasses-operator/server/mediamtx

# Directory for recordings and analysis output
# Recordings: session_<id>.mp4  |  Analysis: analysis_<id>.txt
RECORDING_DIR=/tmp

# Optional: override the analysis prompt
# GEMINI_PROMPT=Analyze the lab protocol shown in this video and return structured JSON...
